{
  "project": "CrabQuant",
  "git_remote": "origin",
  "base_branch": "main",
  "branch_prefix": "night",
  "auto_merge": false,
  "conflicting_crons": {
    "crabquant-supervisor": "c7abaf36-c1ce-4510-9e43-7f02771af8c8",
    "crabquant-validate": "69fd7ce3-b875-4a22-96cd-1a72896ca83f"
  },
  "venv": "/home/Zev/development/QuantFactory/.venv/bin/activate",
  "test_commands": {
    "unit": "cd ~/development/CrabQuant && source /home/Zev/development/QuantFactory/.venv/bin/activate && python -m pytest tests/refinement/ -v --tb=short --ignore=tests/refinement/test_e2e.py --ignore=tests/refinement/test_e2e_phase2.py --ignore=tests/refinement/test_e2e_phase3.py",
    "e2e": "cd ~/development/CrabQuant && source /home/Zev/development/QuantFactory/.venv/bin/activate && python -m pytest tests/refinement/test_e2e.py tests/refinement/test_e2e_phase2.py tests/refinement/test_e2e_phase3.py -v --tb=short",
    "stress": null
  },
  "lint_command": "cd ~/development/CrabQuant && source /home/Zev/development/QuantFactory/.venv/bin/activate && ruff check crabquant/ tests/",
  "type_check_command": null,
  "build_command": null,
  "dependency_files": ["requirements.txt", "pyproject.toml"],
  "api_budget": {
    "max_llm_calls": 150,
    "max_cost_usd": 5.00,
    "cost_per_call": 0.015,
    "throttle_model": "zai/glm-4.7"
  },
  "model": "zai/glm-5-turbo",
  "subagent_model": "zai/glm-5-turbo",
  "max_parallel_agents": 3,
  "review_strictness": "normal",
  "scope_limited_to": ["/home/Zev/development/CrabQuant/"],
  "resource_limits": {
    "min_disk_gb": 1,
    "min_ram_gb": 2
  },
  "existing_daemons": [
    {
      "name": "crabquant-daemon",
      "pid_file": "crabquant.pid",
      "status_check": "cd ~/development/CrabQuant && source /home/Zev/development/QuantFactory/.venv/bin/activate && python scripts/run_pipeline.py --status",
      "action": "pause_if_conflict"
    }
  ],
  "research": {
    "enabled": false,
    "confidence_threshold": "medium",
    "min_sources_for_validation": 2,
    "plagiarism_prevention": true
  },
  "iteration": {
    "enabled": false,
    "budget_max_llm_calls": 50,
    "budget_max_cost_usd": 2.00,
    "max_cycles": 1,
    "max_improvements_per_cycle": 3,
    "auto_approve_max_effort": "medium",
    "protected_paths": [],
    "require_vision_md": true,
    "stop_on_regression": true,
    "max_consecutive_failures": 3,
    "convergence_threshold": 0.1,
    "max_internet_fetches_per_cycle": 5,
    "tdd_required_for_tier": [2, 3],
    "deadletter_max_attempts": 3,
    "step_timeout_minutes": 30
  },
  "final_review": {
    "enabled": true,
    "time_budget_minutes": 15,
    "max_fix_iterations": 1,
    "max_fix_agents": 1,
    "block_on_critical": true,
    "block_on_important": false,
    "skip_checks": [],
    "auto_fix": true
  }
}
