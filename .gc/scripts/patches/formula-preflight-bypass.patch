+// runOrderPreflight executes budget and circuit-breaker guardrails before any order.
+// It checks for guardrail scripts in the city's scripts/ directory and runs them.
+// If no scripts are found, it's a no-op (non-HermGC deployments don't have them).
+func runOrderPreflight(ctx context.Context, cityPath string, a orders.Order, stderr io.Writer) error {
+	scriptsDir := filepath.Join(cityPath, "scripts")
+	budgetCheck := filepath.Join(scriptsDir, "budget-check.sh")
+	circuitBreaker := filepath.Join(scriptsDir, "circuit-breaker.sh")
+
+	// Budget preflight — check if daily budget allows dispatch
+	if info, err := os.Stat(budgetCheck); err == nil && info.Mode().Perm()&0111 != 0 {
+		ctx, cancel := context.WithTimeout(ctx, 10*time.Second)
+		defer cancel()
+		cmd := exec.CommandContext(ctx, budgetCheck, "preflight")
+		cmd.Env = append(os.Environ(), fmt.Sprintf("GC_CITY=%s", cityPath))
+		if output, err := cmd.CombinedOutput(); err != nil {
+			logDispatchError(stderr, "gc: order dispatch preflight: budget check failed for %s: %s", a.ScopedName(), string(output))
+			return fmt.Errorf("budget preflight failed: %s", strings.TrimSpace(string(output)))
+		}
+	}
+
+	// Circuit breaker — check if the target agent is circuit-broken
+	// For formula orders, the "bead-id" is the order's scoped name
+	if info, err := os.Stat(circuitBreaker); err == nil && info.Mode().Perm()&0111 != 0 {
+		ctx, cancel := context.WithTimeout(ctx, 10*time.Second)
+		defer cancel()
+		cmd := exec.CommandContext(ctx, circuitBreaker, "check", a.ScopedName())
+		cmd.Env = append(os.Environ(), fmt.Sprintf("GC_CITY=%s", cityPath))
+		if output, err := cmd.CombinedOutput(); err != nil {
+			logDispatchError(stderr, "gc: order dispatch preflight: circuit breaker tripped for %s: %s", a.ScopedName(), string(output))
+			return fmt.Errorf("circuit breaker tripped: %s", strings.TrimSpace(string(output)))
+		}
+	}
+
+	return nil
+}
